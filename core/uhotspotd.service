[Unit]
Description=UniFi Hotspot Manager Daemon
After=network.target pydhcpd.service
Wants=pydhcpd.service

[Service]
Type=simple
ExecStart=/etc/uhotspot/core/uhotspotd.sh
Restart=always
RestartSec=10
PrivateTmp=yes
ProtectHome=read-only
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectKernelLogs=yes
LockPersonality=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes

[Install]
WantedBy=multi-user.target
